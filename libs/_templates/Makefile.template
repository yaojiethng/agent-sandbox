# Makefile â€” <project-name>
# agent-sandbox template version: 2
# Runs agent-sandbox against this project.
# Requires agent-sandbox CLI installed on the host:
#   make install  (from the agent-sandbox repo)
#
# PROJECT_DIR and SANDBOX_DIR are read from .env in the same directory as
# this Makefile. Both are written by: agent-sandbox onboard
#
# If .env is missing, run:
#   agent-sandbox onboard --name=<n> --project=<path> --sandbox=<path>
#
# Paths must be WSL/Linux format. To convert a Windows path:
#   wslpath 'C:\Users\you\Projects\my-project'
#
# PROVIDER SELECTION
#   Pass a provider name as a trailing argument to select a reasoning layer.
#   Default provider is opencode.
#
#   make start            â†’ opencode (default)
#   make start hermes     â†’ hermes
#   make serve hermes     â†’ hermes in serve mode
#   make dry-run hermes   â†’ hermes dry-run

-include .env
export

PROJECT_NAME := <project-name>
PROJECT_DIR  ?= $(error PROJECT_DIR not set â€” .env missing or incomplete. Run: agent-sandbox onboard --name=$(PROJECT_NAME) --project=<path> --sandbox=<path>)
SANDBOX_DIR  ?= $(error SANDBOX_DIR not set â€” .env missing or incomplete. Run: agent-sandbox onboard --name=$(PROJECT_NAME) --project=<path> --sandbox=<path>)
AGENT_BRIEF  := agents.md
ENV_FILE     := .env

# Provider passthrough â€” trailing argument after the target name.
# e.g. make start hermes â†’ --provider=hermes
# If not supplied, start_agent.sh defaults to opencode.
PROVIDER     := $(wordlist 2,99,$(MAKECMDGOALS))
PROVIDER_ARG := $(if $(PROVIDER),--provider=$(PROVIDER),)

# Suppress "no rule to make target '<provider>'" for passthrough words.
%:
	@:

.PHONY: build build-sandbox build-agent build-all
.PHONY: start serve dry-run apply
.PHONY: rebuild rebuild-start rebuild-serve rebuild-dry-run

# -------------------------
# Build
# -------------------------

build: build-all

build-sandbox:
	agent-sandbox build sandbox \
	  --name=$(PROJECT_NAME) \
	  --sandbox=$(SANDBOX_DIR)

build-agent:
	agent-sandbox build agent \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR)

build-all:
	agent-sandbox build all \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR)

# -------------------------
# Run
# -------------------------

start:
	-agent-sandbox start \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE) \
	  $(PROVIDER_ARG)

serve:
	-agent-sandbox serve \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE) \
	  $(PROVIDER_ARG)

dry-run:
	agent-sandbox dry-run \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE) \
	  $(PROVIDER_ARG)

# -------------------------
# Apply
# -------------------------

apply:
	agent-sandbox apply \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  $(if $(BRANCH),--branch=$(BRANCH),)

# -------------------------
# Rebuild (force rebuild all images, then start)
# -------------------------

rebuild: rebuild-start

rebuild-start:
	-agent-sandbox rebuild start \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE) \
	  $(PROVIDER_ARG)

rebuild-serve:
	-agent-sandbox rebuild serve \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE) \
	  $(PROVIDER_ARG)

rebuild-dry-run:
	agent-sandbox rebuild dry-run \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE) \
	  $(PROVIDER_ARG)
