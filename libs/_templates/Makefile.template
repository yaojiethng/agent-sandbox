# Makefile ‚Äî <project-name>
# agent-sandbox template version: 3
# Runs agent-sandbox against this project.
# Requires agent-sandbox CLI installed on the host:
#   make install  (from the agent-sandbox repo)
#
# PROJECT_DIR and SANDBOX_DIR are read from .env in the same directory as
# this Makefile. Both are written by: agent-sandbox onboard
#
# If .env is missing, run:
#   agent-sandbox onboard --name=<n> --project=<path> --sandbox=<path>
#
# Paths must be WSL/Linux format. To convert a Windows path:
#   wslpath 'C:\Users\you\Projects\my-project'
#
# PROVIDER
#   Required for all run targets. Pass as a Make variable.
#   Example: make start PROVIDER=hermes
#
# REBUILD
#   Optional. Rebuilds provider image before running (base skipped if exists).
#   Example: make start PROVIDER=hermes REBUILD=1
#
# REBUILD_BASE
#   Optional. Forces a full rebuild of the base and provider images.
#   Use when system packages or the agent runtime version has changed.
#   Example: make build REBUILD_BASE=1
#   Example: make start PROVIDER=hermes REBUILD=1 REBUILD_BASE=1
#
# BUILD TARGETS
#   make build                        ‚Äî builds sandbox + all providers
#   make build TARGET=all             ‚Äî explicit alias for build-all
#   make build TARGET=hermes          ‚Äî builds hermes provider only
#   make build TARGET=hermes,sandbox  ‚Äî builds hermes and sandbox
#   make build REBUILD_BASE=1         ‚Äî forces full rebuild including base images
#
# STOP
#   make stop                         ‚Äî stop and remove all session containers and volumes

-include .env
export

PROJECT_NAME := <project-name>
PROJECT_DIR  ?= $(error PROJECT_DIR not set ‚Äî .env missing or incomplete. Run: agent-sandbox onboard --name=$(PROJECT_NAME) --project=<path> --sandbox=<path>)
SANDBOX_DIR  ?= $(error SANDBOX_DIR not set ‚Äî .env missing or incomplete. Run: agent-sandbox onboard --name=$(PROJECT_NAME) --project=<path> --sandbox=<path>)
AGENT_BRIEF  := AGENTS.md
ENV_FILE     := .env
PROVIDER     ?=
REBUILD      ?=
REBUILD_BASE ?=
TARGET       ?=
SESSION      ?=
TARGET_BRANCH ?=

REBUILD_FLAG      = $(if $(REBUILD),--rebuild,)
REBUILD_BASE_FLAG = $(if $(REBUILD_BASE),--rebuild-base,)
PROVIDER_FLAG     = $(if $(PROVIDER),--provider=$(PROVIDER),)
TARGET_FLAG       = --target=$(if $(TARGET),$(TARGET),all)

.PHONY: build start serve dry-run stop apply draft confirm reject refresh

# -------------------------
# Build
# -------------------------

build:
	agent-sandbox build \
	  $(TARGET_FLAG) \
	  $(REBUILD_BASE_FLAG) \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR)

# -------------------------
# Run
# -------------------------

start:
	agent-sandbox start \
	  $(PROVIDER_FLAG) \
	  $(REBUILD_FLAG) \
	  $(REBUILD_BASE_FLAG) \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE)

serve:
	agent-sandbox serve \
	  $(PROVIDER_FLAG) \
	  $(REBUILD_FLAG) \
	  $(REBUILD_BASE_FLAG) \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE)

dry-run:
	agent-sandbox dry-run \
	  $(PROVIDER_FLAG) \
	  $(REBUILD_FLAG) \
	  $(REBUILD_BASE_FLAG) \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE)

# -------------------------
# Stop
# -------------------------

stop:
	agent-sandbox stop \
	  --name=$(PROJECT_NAME) \
	  --sandbox=$(SANDBOX_DIR)

# -------------------------
# Apply workflow
# -------------------------
#
# WORKFLOW:
#   make draft                    ‚Äî apply session patches to a working branch for review
#   make draft SESSION=<name>     ‚Äî apply a specific named session
#   git log -p HEAD~N..HEAD       ‚Äî review changes on the working branch
#   make confirm                  ‚Äî rebase + fast-forward merge to source branch
#   make confirm TARGET_BRANCH=x  ‚Äî merge to a different target branch
#   make reject                   ‚Äî discard draft branch, return to source branch
#
# LEGACY (reasoning layer output channel):
#   make apply                    ‚Äî apply changes.diff from .workspace/output/ (no commits created)
#   make apply SESSION=<name>     ‚Äî apply from a specific named session directory
#   make apply BRANCH=<name>      ‚Äî apply to a named branch
#   make apply FORCE=1            ‚Äî apply with --reject; .rej files created for conflicts
#   Note: OUTPUT_DIR is not cleared automatically. Clear manually between sessions if desired.

draft:
	agent-sandbox draft \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  $(if $(SESSION),--session=$(SESSION),) \
	  $(if $(BRANCH_FROM),--branch-from=$(BRANCH_FROM),) \
	  $(if $(DIFFS),--diffs=$(DIFFS),)

confirm:
	agent-sandbox confirm \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  $(if $(TARGET_BRANCH),--target=$(TARGET_BRANCH),)

reject:
	agent-sandbox reject \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR)

apply:
	agent-sandbox apply \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  $(if $(SESSION),--session=$(SESSION),) \
	  $(if $(BRANCH),--branch=$(BRANCH),) \
	  $(if $(DIFF),--diff=$(DIFF),) \
	  $(if $(FORCE),--force,)

# -------------------------
# Harness maintenance
# -------------------------
#
# refresh: update stale template files and re-register git aliases after a
# harness update. Safe to run repeatedly ‚Äî does not overwrite .env or AGENTS.md.

refresh:
	agent-sandbox onboard --refresh \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR)
