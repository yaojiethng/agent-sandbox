# Makefile ā€” <project-name>
# agent-sandbox template version: 3
# Runs agent-sandbox against this project.
# Requires agent-sandbox CLI installed on the host:
#   make install  (from the agent-sandbox repo)
#
# PROJECT_DIR and SANDBOX_DIR are read from .env in the same directory as
# this Makefile. Both are written by: agent-sandbox onboard
#
# If .env is missing, run:
#   agent-sandbox onboard --name=<n> --project=<path> --sandbox=<path>
#
# Paths must be WSL/Linux format. To convert a Windows path:
#   wslpath 'C:\Users\you\Projects\my-project'
#
# PROVIDER
#   Required for all run targets. Pass as a Make variable.
#   Example: make start PROVIDER=hermes
#
# REBUILD
#   Optional. Rebuilds provider image before running (base skipped if exists).
#   Example: make start PROVIDER=hermes REBUILD=1
#
# REBUILD_BASE
#   Optional. Forces a full rebuild of the base and provider images.
#   Use when system packages or the agent runtime version has changed.
#   Example: make build REBUILD_BASE=1
#   Example: make start PROVIDER=hermes REBUILD=1 REBUILD_BASE=1
#
# BUILD TARGETS
#   make build                        ā€” builds sandbox + all providers
#   make build TARGET=all             ā€” explicit alias for build-all
#   make build TARGET=hermes          ā€” builds hermes provider only
#   make build TARGET=hermes,sandbox  ā€” builds hermes and sandbox
#   make build REBUILD_BASE=1         ā€” forces full rebuild including base images
#
# STOP
#   make stop                         ā€” stop and remove all session containers and volumes

-include .env
export

PROJECT_NAME := <project-name>
PROJECT_DIR  ?= $(error PROJECT_DIR not set ā€” .env missing or incomplete. Run: agent-sandbox onboard --name=$(PROJECT_NAME) --project=<path> --sandbox=<path>)
SANDBOX_DIR  ?= $(error SANDBOX_DIR not set ā€” .env missing or incomplete. Run: agent-sandbox onboard --name=$(PROJECT_NAME) --project=<path> --sandbox=<path>)
AGENT_BRIEF  := agents.md
ENV_FILE     := .env
PROVIDER     ?=
REBUILD      ?=
REBUILD_BASE ?=
TARGET       ?=

REBUILD_FLAG      = $(if $(REBUILD),--rebuild,)
REBUILD_BASE_FLAG = $(if $(REBUILD_BASE),--rebuild-base,)
PROVIDER_FLAG     = $(if $(PROVIDER),--provider=$(PROVIDER),)
TARGET_FLAG       = --target=$(if $(TARGET),$(TARGET),all)

.PHONY: build start serve dry-run stop apply

# -------------------------
# Build
# -------------------------

build:
	agent-sandbox build \
	  $(TARGET_FLAG) \
	  $(REBUILD_BASE_FLAG) \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR)

# -------------------------
# Run
# -------------------------

start:
	agent-sandbox start \
	  $(PROVIDER_FLAG) \
	  $(REBUILD_FLAG) \
	  $(REBUILD_BASE_FLAG) \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE)

serve:
	agent-sandbox serve \
	  $(PROVIDER_FLAG) \
	  $(REBUILD_FLAG) \
	  $(REBUILD_BASE_FLAG) \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE)

dry-run:
	agent-sandbox dry-run \
	  $(PROVIDER_FLAG) \
	  $(REBUILD_FLAG) \
	  $(REBUILD_BASE_FLAG) \
	  --name=$(PROJECT_NAME) \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  --brief=$(AGENT_BRIEF) \
	  --env=$(ENV_FILE)

# -------------------------
# Stop
# -------------------------

stop:
	agent-sandbox stop \
	  --name=$(PROJECT_NAME) \
	  --sandbox=$(SANDBOX_DIR)

# -------------------------
# Apply
# -------------------------

apply:
	agent-sandbox apply \
	  --project=$(PROJECT_DIR) \
	  --sandbox=$(SANDBOX_DIR) \
	  $(if $(BRANCH),--branch=$(BRANCH),)
